        <dc:Bounds x="1536" y="230" width="154" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="_shape_creditGw" bpmnElement="_creditGw">
        <dc:Bounds x="1750" y="232" width="56" height="56" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="_shape_notifyCreditRejected" bpmnElement="_notifyCreditRejected">
        <dc:Bounds x="1866" y="390" width="154" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="_shape_endCreditRejected" bpmnElement="_endCreditRejected">
        <dc:Bounds x="2080" y="392" width="56" height="56" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="_shape_sendContract" bpmnElement="_sendContract">
        <dc:Bounds x="1866" y="230" width="154" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="_shape_paymentReceived" bpmnElement="_paymentReceived">
        <dc:Bounds x="2080" y="232" width="56" height="56" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="_shape_payProvider" bpmnElement="_payProvider">
        <dc:Bounds x="2196" y="230" width="154" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="_shape_forkNotify" bpmnElement="_forkNotify">
        <dc:Bounds x="2410" y="232" width="56" height="56" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="_shape_notifyProviderEstablished" bpmnElement="_notifyProviderEstablished">
        <dc:Bounds x="2526" y="130" width="154" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="_shape_notifyUserEstablished" bpmnElement="_notifyUserEstablished">
        <dc:Bounds x="2526" y="330" width="154" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="_shape_joinNotify" bpmnElement="_joinNotify">
        <dc:Bounds x="2740" y="232" width="56" height="56" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="_shape_endEstablished" bpmnElement="_endEstablished">
        <dc:Bounds x="2856" y="232" width="56" height="56" />
      </bpmndi:BPMNShape>
