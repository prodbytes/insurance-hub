  <import id="_IMP00001-0000-0000-0000-000000000001" name="vehicleValues" importType="https://www.omg.org/spec/DMN/20230324/MODEL/" namespace="https://kie.org/dmn/_7A1C2F44-9E01-4B4A-8D2C-3F5E6A7B8C9D" locationURI="carEstimatedValue.dmn" xmlns:drools="http://www.drools.org/kie/dmn/1.1" drools:modelName="carEstimatedValue" />
  <decision name="carEstimatedValue" id="_0AFAFF2E-34CB-4235-8145-2A6ECAD61F34">
    <variable name="carEstimatedValue" id="_A835F10F-7DE5-44A5-A189-ADD7A7268211" typeRef="number" />
    <informationRequirement id="_8F19E6EE-CA1A-4015-B219-00BB52FFE10D">
      <requiredInput href="#_9568137B-518F-4725-BD1B-DD949FF2110A" />
    </informationRequirement>
    <informationRequirement id="_464272BF-00A2-4C31-9FF4-9ACA9A2027C4">
      <requiredInput href="#_ABE17F77-8AB4-4C04-AEF6-0BB6078EB919" />
    </informationRequirement>
    <informationRequirement id="_4085BB84-F70D-4BB3-A50B-E285BDE0A11F">
      <requiredInput href="#_24D29BCE-48B3-4EA4-89A4-252787F1E4DF" />
    </informationRequirement>
    <knowledgeRequirement id="_KRQ00001-0000-0000-0000-000000000001">
      <requiredKnowledge href="https://kie.org/dmn/_7A1C2F44-9E01-4B4A-8D2C-3F5E6A7B8C9D#_VVBKM001-0000-0000-0000-000000000001" />
    </knowledgeRequirement>
    <literalExpression id="_EVV00001-0000-0000-0000-000000000010" typeRef="number">
      <text>vehicleValues.carEstimatedValue(Make, Model, Year)</text>
    </literalExpression>
  </decision>
  <decision name="Mileage Risk" id="_MR000001-0000-0000-0000-000000000001">
    <variable name="Mileage Risk" id="_MR000001-0000-0000-0000-000000000002" typeRef="number" />
    <informationRequirement id="_MR000001-0000-0000-0000-0000000000A1">
      <requiredInput href="#_36C0C743-1E55-4C43-8DDD-89B5757EDC7E" />
    </informationRequirement>
    <decisionTable id="_MR000001-0000-0000-0000-000000000010" typeRef="number" hitPolicy="UNIQUE" label="Mileage Risk">
      <input id="_MR000001-0000-0000-0000-000000000011">
        <inputExpression id="_MR000001-0000-0000-0000-000000000012" typeRef="number">
          <text>Mileage</text>
        </inputExpression>
      </input>
      <output id="_MR000001-0000-0000-0000-000000000013" />
      <annotation name="Annotations" />
      <rule id="_MR000001-0000-0000-0000-000000000021">
        <inputEntry id="_MR000001-0000-0000-0000-000000000022">
          <text>&lt; 7500</text>
        </inputEntry>
        <outputEntry id="_MR000001-0000-0000-0000-000000000023">
          <text>0</text>
        </outputEntry>
        <annotationEntry>
          <text>Low annual mileage</text>
        </annotationEntry>
      </rule>
      <rule id="_MR000001-0000-0000-0000-000000000031">
        <inputEntry id="_MR000001-0000-0000-0000-000000000032">
          <text>[7500..15000]</text>
        </inputEntry>
        <outputEntry id="_MR000001-0000-0000-0000-000000000033">
          <text>1</text>
        </outputEntry>
        <annotationEntry>
          <text>Average annual mileage</text>
        </annotationEntry>
      </rule>
      <rule id="_MR000001-0000-0000-0000-000000000041">
        <inputEntry id="_MR000001-0000-0000-0000-000000000042">
          <text>&gt; 15000</text>
        </inputEntry>
        <outputEntry id="_MR000001-0000-0000-0000-000000000043">
          <text>2</text>
        </outputEntry>
        <annotationEntry>
          <text>High annual mileage</text>
        </annotationEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision name="Age Risk" id="_AR000001-0000-0000-0000-000000000001">
    <variable name="Age Risk" id="_AR000001-0000-0000-0000-000000000002" typeRef="number" />
    <informationRequirement id="_AR000001-0000-0000-0000-0000000000A1">
      <requiredInput href="#_DA000001-0000-0000-0000-000000000001" />
    </informationRequirement>
    <decisionTable id="_AR000001-0000-0000-0000-000000000010" typeRef="number" hitPolicy="UNIQUE" label="Age Risk">
      <input id="_AR000001-0000-0000-0000-000000000011">
        <inputExpression id="_AR000001-0000-0000-0000-000000000012" typeRef="number">
          <text>Driver Age</text>
        </inputExpression>
      </input>
      <output id="_AR000001-0000-0000-0000-000000000013" />
      <annotation name="Annotations" />
      <rule id="_AR000001-0000-0000-0000-000000000021">
        <inputEntry id="_AR000001-0000-0000-0000-000000000022">
          <text>&lt; 25</text>
        </inputEntry>
        <outputEntry id="_AR000001-0000-0000-0000-000000000023">
          <text>2</text>
        </outputEntry>
        <annotationEntry>
          <text>Young driver</text>
        </annotationEntry>
      </rule>
      <rule id="_AR000001-0000-0000-0000-000000000031">
        <inputEntry id="_AR000001-0000-0000-0000-000000000032">
          <text>[25..70]</text>
        </inputEntry>
        <outputEntry id="_AR000001-0000-0000-0000-000000000033">
          <text>0</text>
        </outputEntry>
        <annotationEntry>
          <text>Experienced driver</text>
        </annotationEntry>
      </rule>
      <rule id="_AR000001-0000-0000-0000-000000000041">
        <inputEntry id="_AR000001-0000-0000-0000-000000000042">
          <text>&gt; 70</text>
        </inputEntry>
        <outputEntry id="_AR000001-0000-0000-0000-000000000043">
          <text>1</text>
        </outputEntry>
        <annotationEntry>
          <text>Senior driver</text>
        </annotationEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision name="Accident Risk" id="_KR000001-0000-0000-0000-000000000001">
    <variable name="Accident Risk" id="_KR000001-0000-0000-0000-000000000002" typeRef="number" />
    <informationRequirement id="_KR000001-0000-0000-0000-0000000000A1">
      <requiredInput href="#_AC000001-0000-0000-0000-000000000001" />
    </informationRequirement>
    <decisionTable id="_KR000001-0000-0000-0000-000000000010" typeRef="number" hitPolicy="UNIQUE" label="Accident Risk">
      <input id="_KR000001-0000-0000-0000-000000000011">
        <inputExpression id="_KR000001-0000-0000-0000-000000000012" typeRef="boolean">
          <text>Accidents</text>
        </inputExpression>
      </input>
      <output id="_KR000001-0000-0000-0000-000000000013" />
      <annotation name="Annotations" />
      <rule id="_KR000001-0000-0000-0000-000000000021">
        <inputEntry id="_KR000001-0000-0000-0000-000000000022">
          <text>true</text>
        </inputEntry>
        <outputEntry id="_KR000001-0000-0000-0000-000000000023">
          <text>2</text>
        </outputEntry>
        <annotationEntry>
          <text>Accident in the last 5 years</text>
        </annotationEntry>
      </rule>
      <rule id="_KR000001-0000-0000-0000-000000000031">
        <inputEntry id="_KR000001-0000-0000-0000-000000000032">
          <text>false</text>
        </inputEntry>
        <outputEntry id="_KR000001-0000-0000-0000-000000000033">
          <text>0</text>
        </outputEntry>
        <annotationEntry>
          <text>No recent accidents</text>
        </annotationEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision name="Ticket Risk" id="_TR000001-0000-0000-0000-000000000001">
    <variable name="Ticket Risk" id="_TR000001-0000-0000-0000-000000000002" typeRef="number" />
    <informationRequirement id="_TR000001-0000-0000-0000-0000000000A1">
      <requiredInput href="#_TK000001-0000-0000-0000-000000000001" />
    </informationRequirement>
    <decisionTable id="_TR000001-0000-0000-0000-000000000010" typeRef="number" hitPolicy="UNIQUE" label="Ticket Risk">
      <input id="_TR000001-0000-0000-0000-000000000011">
        <inputExpression id="_TR000001-0000-0000-0000-000000000012" typeRef="boolean">
          <text>Tickets</text>
        </inputExpression>
      </input>
      <output id="_TR000001-0000-0000-0000-000000000013" />
      <annotation name="Annotations" />
      <rule id="_TR000001-0000-0000-0000-000000000021">
        <inputEntry id="_TR000001-0000-0000-0000-000000000022">
          <text>true</text>
        </inputEntry>
        <outputEntry id="_TR000001-0000-0000-0000-000000000023">
          <text>1</text>
        </outputEntry>
        <annotationEntry>
          <text>Traffic violation in the last 3 years</text>
        </annotationEntry>
      </rule>
      <rule id="_TR000001-0000-0000-0000-000000000031">
        <inputEntry id="_TR000001-0000-0000-0000-000000000032">
          <text>false</text>
        </inputEntry>
        <outputEntry id="_TR000001-0000-0000-0000-000000000033">
          <text>0</text>
        </outputEntry>
        <annotationEntry>
          <text>No recent violations</text>
        </annotationEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision name="Risk Index" id="_RI000001-0000-0000-0000-000000000001">
    <variable name="Risk Index" id="_RI000001-0000-0000-0000-000000000002" typeRef="number" />
    <informationRequirement id="_RI000001-0000-0000-0000-0000000000A1">
      <requiredDecision href="#_MR000001-0000-0000-0000-000000000001" />
    </informationRequirement>
    <informationRequirement id="_RI000001-0000-0000-0000-0000000000A2">
      <requiredDecision href="#_AR000001-0000-0000-0000-000000000001" />
    </informationRequirement>
    <informationRequirement id="_RI000001-0000-0000-0000-0000000000A3">
      <requiredDecision href="#_KR000001-0000-0000-0000-000000000001" />
    </informationRequirement>
    <informationRequirement id="_RI000001-0000-0000-0000-0000000000A4">
      <requiredDecision href="#_TR000001-0000-0000-0000-000000000001" />
    </informationRequirement>
    <literalExpression id="_RI000001-0000-0000-0000-000000000010" typeRef="number">
      <text>Mileage Risk + Age Risk + Accident Risk + Ticket Risk</text>
    </literalExpression>
  </decision>
  <decision name="Risk Rate" id="_RR000001-0000-0000-0000-000000000001">
    <variable name="Risk Rate" id="_RR000001-0000-0000-0000-000000000002" typeRef="number" />
    <informationRequirement id="_RR000001-0000-0000-0000-0000000000A1">
      <requiredDecision href="#_RI000001-0000-0000-0000-000000000001" />
    </informationRequirement>
    <literalExpression id="_RR000001-0000-0000-0000-000000000010" typeRef="number">
      <text>0.04 * (1 + Risk Index * 0.15)</text>
    </literalExpression>
  </decision>
  <decision name="Insurance Premium" id="_IP000001-0000-0000-0000-000000000001">
    <variable name="Insurance Premium" id="_IP000001-0000-0000-0000-000000000002" typeRef="number" />
    <informationRequirement id="_IP000001-0000-0000-0000-0000000000A1">
      <requiredDecision href="#_0AFAFF2E-34CB-4235-8145-2A6ECAD61F34" />
    </informationRequirement>
    <informationRequirement id="_IP000001-0000-0000-0000-0000000000A2">
      <requiredDecision href="#_RR000001-0000-0000-0000-000000000001" />
    </informationRequirement>
    <literalExpression id="_IP000001-0000-0000-0000-000000000010" typeRef="number">
      <text>carEstimatedValue * Risk Rate</text>
    </literalExpression>
  </decision>
