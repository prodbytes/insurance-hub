// Dev container for insurance-hub.
// Works out of the box in GitHub Codespaces (and local VS Code Dev Containers):
// devbox provides the JDK/Quarkus toolchain, docker-in-docker runs the Postgres
// and decision-control containers, and the services start automatically on boot.
{
  "name": "insurance-hub",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "devbox",

  "features": {
    // process-compose launches the database + decision-control via `docker run`,
    // so the container needs its own Docker daemon.
    // moby:false -> install upstream Docker CE; the devbox base is Debian trixie,
    // which has no moby-cli packages (the feature's default moby:true fails there).
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    // gh CLI, baked in at build time so start.sh never has to download it
    // (used to set port 8080 public in Codespaces).
    "ghcr.io/devcontainers/features/github-cli:1": {},
    // A standalone JDK on a stable path (JAVA_HOME) so the VS Code Java
    // language server can compile. GraalVM CE 25 (SDKMAN id `25.0.2-graalce`),
    // matching devbox's graalvm-ce. The Maven build itself uses devbox via mvnw.
    "ghcr.io/devcontainers/features/java:1": {
      "version": "25.0.2-graalce"
    }
  },

  "forwardPorts": [8080, 8081, 5432],
  "portsAttributes": {
    "8080": { "label": "ih-vdn", "onAutoForward": "silent", "visibility": "public" },
    "8081": { "label": "decision-control", "onAutoForward": "silent" },
    "5432": { "label": "postgres", "onAutoForward": "silent" }
  },

  // Optional: provide the private Decision Control image via a Codespaces
  // secret named DECISION_CONTROL_IMAGE. If unset, .env's value (if any) is
  // used; otherwise the decision-control process simply stays red.
  //
  // ALETYX_* are Codespaces secrets holding the private-registry credentials;
  // start.sh uses them to `docker login` so decision-control can be pulled.
  // (Codespaces injects these as env vars; this passthrough also surfaces them
  // to local Dev Containers when exported on the host.)
  "containerEnv": {
    "DECISION_CONTROL_IMAGE": "${localEnv:DECISION_CONTROL_IMAGE}",
    "ALETYX_REGISTRY": "${localEnv:ALETYX_REGISTRY}",
    "ALETYX_USERNAME": "${localEnv:ALETYX_USERNAME}",
    "ALETYX_PASSWORD": "${localEnv:ALETYX_PASSWORD}"
  },

  // Pre-link the devbox packages into this workspace and seed .env once at
  // create time (the image already warmed the nix store, so this is fast).
  "onCreateCommand": "devbox install; [ -f .env ] || cp .env.example .env",

  // Start all processes in the background on every boot. decision-control may
  // stay red without a private image / registry login — that's fine, the other
  // services come up independently.
  "postStartCommand": "bash .devcontainer/start.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.java",
        "redhat.vscode-quarkus",
        "jetpack-io.devbox"
      ],
      // The java feature installs via SDKMAN to this stable path and sets
      // JAVA_HOME; point the language server at it so it can compile.
      "settings": {
        "java.jdt.ls.java.home": "/usr/local/sdkman/candidates/java/current",
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-25",
            "path": "/usr/local/sdkman/candidates/java/current",
            "default": true
          }
        ]
      }
    }
  }
}
