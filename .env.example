# Copy to .env (the dev container does this automatically on first boot).
# Local-dev datasource credentials: Quarkus reads these env vars natively
# (overriding application-dev.properties) and process-compose injects the
# username/password into the PostgreSQL container.
QUARKUS_DATASOURCE_USERNAME=quarkus
QUARKUS_DATASOURCE_PASSWORD=quarkus
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://localhost:5432/insurancehub

# Decision Control runs from a private registry image. To enable it:
#   1. Set this to the image ref (or provide it as a Codespaces secret named
#      DECISION_CONTROL_IMAGE).
#   2. Authenticate: docker login registry-innovator.aletyx.services
# Left unset, the decision-control process stays red but everything else runs.
# DECISION_CONTROL_IMAGE=registry-innovator.aletyx.services/decision-control-innovator:1.4.0
