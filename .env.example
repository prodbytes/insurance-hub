# Local dev datasource credentials.
# Quarkus reads these env vars natively (they override application-dev.properties),
# and process-compose injects them into the PostgreSQL container.
QUARKUS_DATASOURCE_USERNAME=dbuser
QUARKUS_DATASOURCE_PASSWORD=CAFEBABE
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://localhost:5432/insurancehub

DC_DATASOURCE_USERNAME=dbuser
DC_DATASOURCE_PASSWORD=CAFEBABE
DC_DATASOURCE_JDBC_URL=jdbc:postgresql://host.docker.internal:5432/insurancehub


DECISION_CONTROL_IMAGE=registry-innovator.aletyx.services/decision-control-innovator:1.4.0
